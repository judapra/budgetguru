{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Budget Guru application.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the User entity." },
        "email": { "type": "string", "description": "User's email address.", "format": "email" },
        "name": { "type": "string", "description": "The full name of the user." }
      },
      "required": ["id", "email", "name"]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a user's company.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Company entity." },
        "userId": { "type": "string", "description": "Reference to User. (Relationship: User 1:1 Company)" },
        "name": { "type": "string", "description": "The name of the company." }
      },
      "required": ["id", "userId", "name"]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense record.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Expense entity." },
        "userId": { "type": "string", "description": "Reference to User. (Relationship: User 1:N Expense)" },
        "categoryId": { "type": "string", "description": "Reference to Category. (Relationship: Category 1:N Expense)" },
        "paymentMethod": { "type": "string", "description": "The method of payment used (e.g., credit card, cash)." },
        "date": { "type": "string", "description": "The date of the expense.", "format": "date-time" },
        "amount": { "type": "number", "description": "The amount of the expense." },
        "details": { "type": "string", "description": "Detailed description of the expense." },
        "installment": { "type": "string", "description": "Indicates the installment number of a larger purchase (e.g. '1/12')." },
        "isInstallment": { "type": "boolean", "description": "Indicates if the expense is an installment purchase." }
      },
      "required": ["id", "userId", "categoryId", "paymentMethod", "date", "amount", "details"]
    },
    "Income": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Income",
      "type": "object",
      "description": "Represents an income record.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Income entity." },
        "userId": { "type": "string", "description": "Reference to User. (Relationship: User 1:N Income)" },
        "categoryId": { "type": "string", "description": "Reference to Category. (Relationship: Category 1:N Income)" },
        "receiptMethod": { "type": "string", "description": "The method of receipt (e.g., direct deposit, cash)." },
        "date": { "type": "string", "description": "The date of the income.", "format": "date-time" },
        "amount": { "type": "number", "description": "The amount of the income." },
        "details": { "type": "string", "description": "Detailed description of the income." }
      },
      "required": ["id", "userId", "categoryId", "receiptMethod", "date", "amount", "details"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a category for income or expenses.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Category entity." },
        "userId": { "type": "string", "description": "Reference to User. (Relationship: User 1:N Category)" },
        "name": { "type": "string", "description": "The name of the category (e.g., Groceries, Salary)." },
        "type": { "type": "string", "description": "The type of category (e.g., Income, Expense)." }
      },
      "required": ["id", "userId", "name", "type"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a real estate property.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Property entity." },
        "userId": { "type": "string", "description": "Reference to User. (Relationship: User 1:N Property)" },
        "name": { "type": "string", "description": "The name of the property." },
        "address": { "type": "string", "description": "The address of the property." },
        "grossRent": { "type": "number", "description": "The gross rent of the property." },
        "netRent": { "type": "number", "description": "The net rent of the property." },
        "adminFee": { "type": "number", "description": "The administration fee for the property in percentage." },
        "status": { "type": "string", "description": "The status of the property (e.g. Rented, Vacant).", "enum": ["Alugado", "Vazio"] },
        "tenantName": { "type": "string", "description": "The name of the tenant. If present, status is 'Alugado'." },
        "tenantPhone": { "type": "string", "description": "The phone number of the tenant." }
      },
      "required": ["id", "userId", "name", "address", "grossRent", "netRent", "adminFee", "status"]
    },
    "PropertyExpense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PropertyExpense",
      "type": "object",
      "description": "Represents an expense associated with a real estate property.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the PropertyExpense entity." },
        "propertyId": { "type": "string", "description": "Reference to Property. (Relationship: Property 1:N PropertyExpense)" },
        "date": { "type": "string", "description": "The date of the expense.", "format": "date-time" },
        "description": { "type": "string", "description": "Description of the expense (e.g., IPTU, Condominium)." },
        "amount": { "type": "number", "description": "The amount of the expense." }
      },
      "required": ["id", "propertyId", "date", "description", "amount"]
    },
    "PropertyRecurringExpense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PropertyRecurringExpense",
      "type": "object",
      "description": "Represents a template for a recurring expense on a property.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the PropertyRecurringExpense entity." },
        "propertyId": { "type": "string", "description": "Reference to Property." },
        "userId": { "type": "string", "description": "Reference to User." },
        "startDate": { "type": "string", "description": "The start date of the recurrence.", "format": "date-time" },
        "endDate": { "type": "string", "description": "The end date of the recurrence.", "format": "date-time" },
        "description": { "type": "string", "description": "Description of the recurring expense." },
        "amount": { "type": "number", "description": "The monthly amount of the expense." },
        "destination": { "type": "string", "description": "Where the expense should be recorded ('Personal' or 'Company').", "enum": ["Personal", "Company"] }
      },
      "required": ["id", "propertyId", "userId", "startDate", "endDate", "description", "amount", "destination"]
    },
    "PropertyRent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PropertyRent",
      "type": "object",
      "description": "Represents a rent payment received for a property.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the PropertyRent entity." },
        "propertyId": { "type": "string", "description": "Reference to Property. (Relationship: Property 1:N PropertyRent)" },
        "date": { "type": "string", "description": "The date the rent was received.", "format": "date-time" },
        "amount": { "type": "number", "description": "The amount of the rent received." },
        "details": { "type": "string", "description": "Optional details about the rent payment." },
        "account": { "type": "string", "description": "The bank account where the rent was deposited." },
        "discounts": { "type": "number", "description": "Any discounts applied to the rent payment." },
        "additions": { "type": "number", "description": "Any additions or fees applied to the rent payment." },
        "isAdjustment": { "type": "boolean", "description": "Indicates if this rent entry is a contract adjustment." }
      },
      "required": ["id", "propertyId", "date", "amount", "account"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "schema": { "$ref": "#/entities/User" },
        "description": "Stores user profile information.",
        "permissions": {
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/company/{companyId}",
        "schema": { "$ref": "#/entities/Company" },
        "description": "Stores user's company information.",
        "permissions": {
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/categories/{categoryId}",
        "schema": { "$ref": "#/entities/Category" },
        "description": "Stores personal categories.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "schema": { "$ref": "#/entities/Expense" },
        "description": "Stores personal expense records.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/incomes/{incomeId}",
        "schema": { "$ref": "#/entities/Income" },
        "description": "Stores personal income records.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/company_categories/{categoryId}",
        "schema": { "$ref": "#/entities/Category" },
        "description": "Stores company categories.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/company_expenses/{expenseId}",
        "schema": { "$ref": "#/entities/Expense" },
        "description": "Stores company expense records.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/company_incomes/{incomeId}",
        "schema": { "$ref": "#/entities/Income" },
        "description": "Stores company income records.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/properties/{propertyId}",
        "schema": { "$ref": "#/entities/Property" },
        "description": "Stores properties managed by a user.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/properties/{propertyId}/expenses/{propertyExpenseId}",
        "schema": { "$ref": "#/entities/PropertyExpense" },
        "description": "Stores expenses related to a specific property.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/properties/{propertyId}/recurring_expenses/{recurringExpenseId}",
        "schema": { "$ref": "#/entities/PropertyRecurringExpense" },
        "description": "Stores templates for recurring expenses on a specific property.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      },
      {
        "path": "/users/{userId}/properties/{propertyId}/rents/{rentId}",
        "schema": { "$ref": "#/entities/PropertyRent" },
        "description": "Stores rent payments received for a specific property.",
        "permissions": {
          "list": "request.auth.uid == userId",
          "read": "request.auth.uid == userId",
          "write": "request.auth.uid == userId"
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to ensure data isolation between users and efficient querying. Each user has their own dedicated space for personal and business finances (expenses, incomes, categories) and properties, enabling secure and scalable access control. This design leverages path-based ownership for private data. The design ensures Authorization Independence by avoiding `get()` calls in security rules, relying solely on `request.auth.uid` and the hierarchical path structure to validate ownership. Segregation is achieved as all documents within a user's collection share the same security posture. This makes securing `list` operations straightforward, ensuring that users can only access their own data (QAPs). The structure facilitates the integrity of ownership by associating each document with a specific `userId`. This explicit association, combined with Firestore security rules, guarantees that only authenticated users can access and manipulate their own data."
  }
}

    